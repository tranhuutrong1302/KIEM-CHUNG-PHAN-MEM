{
  "info": {
    "name": "Royal Bid - 02 - Bao ve session (chua dang nhap)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "02 - Bao ve session (chua dang nhap)",
      "item": [
        {
          "name": "02.1 - my_bids chua login -> phai chuyen ve login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Xoa cookie de dam bao chua co session",
                  "pm.cookieJar().clear(pm.variables.replaceIn('{{base_url}}'), function(err) {",
                  "    if (err) { console.log('Clear cookie error:', err); }",
                  "    else { console.log('Cookie cleared'); }",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "var code = pm.response.code;",
                  "",
                  "pm.test('[02.1] Chua login thi bi chay ve trang login', function () {",
                  "    var chuyenVeLogin = body.includes('\\u0110\\u0102NG NH\\u1eacP') && body.includes('btn_login');",
                  "    var redirect302  = (code === 302);",
                  "    pm.expect(chuyenVeLogin || redirect302).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/my_bids.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "my_bids.php"
              ]
            }
          },
          "response": []
        },
        {
          "name": "02.2 - Dat gia chua login -> yeu cau dang nhap",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[02.2] Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[02.2] Yeu cau dang nhap truoc khi dat gia', function () {",
                  "    var coYeuCauLogin = body.includes('\\u0111\\u0103ng nh\\u1eadp') || body.includes('login.php');",
                  "    pm.expect(coYeuCauLogin).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "product_id",
                  "value": "{{product_id}}"
                },
                {
                  "key": "bid_amount",
                  "value": "{{bid_amount}}"
                },
                {
                  "key": "submit_bid",
                  "value": "1"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/index.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "index.php"
              ]
            }
          },
          "response": []
        },
        {
          "name": "02.3 - Dang nhap sai mat khau",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[02.3] Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[02.3] Hien thi thong bao loi dang nhap', function () {",
                  "    var coLoi = body.includes('M\\u1eadt kh\\u1ea9u kh\\u00f4ng ch\\u00ednh x\\u00e1c')",
                  "             || body.includes('T\\u00e0i kho\\u1ea3n kh\\u00f4ng t\\u1ed3n t\\u1ea1i');",
                  "    pm.expect(coLoi).to.eql(true);",
                  "});",
                  "",
                  "pm.test('[02.3] Van o lai trang dang nhap', function () {",
                  "    pm.expect(body).to.include('\\u0110\\u0102NG NH\\u1eacP');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "user_khong_ton_tai"
                },
                {
                  "key": "password",
                  "value": "sai_mat_khau_xyz"
                },
                {
                  "key": "btn_login",
                  "value": "1"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/login.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login.php"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}