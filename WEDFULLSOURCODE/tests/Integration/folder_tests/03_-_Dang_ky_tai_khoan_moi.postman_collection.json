{
  "info": {
    "name": "Royal Bid - 03 - Dang ky tai khoan moi",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "03 - Dang ky tai khoan moi",
      "item": [
        {
          "name": "03.1 - POST Dang ky thanh cong",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Tao username duy nhat moi lan chay de tranh trung",
                  "var newUser = 'pm_' + Date.now();",
                  "pm.environment.set('test_username', newUser);",
                  "pm.environment.set('test_full_name', 'Postman Test User');",
                  "console.log('Dang ky voi username:', newUser);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[03.1] Khong loi server', function () {",
                  "    pm.expect(pm.response.code).to.be.below(500);",
                  "});",
                  "",
                  "pm.test('[03.1] Khong co loi PHP', function () {",
                  "    pm.expect(body).to.not.match(/Fatal error|Parse error/i);",
                  "});",
                  "",
                  "pm.test('[03.1] Dang ky thanh cong - chuyen sang trang login', function () {",
                  "    var thanhCong = body.includes('\\u0110\\u0102NG NH\\u1eacP')",
                  "                && !body.includes('T\\u00ean \\u0111\\u0103ng nh\\u1eadp \\u0111\\u00e3 t\\u1ed3n t\\u1ea1i');",
                  "    pm.expect(thanhCong).to.eql(true);",
                  "});",
                  "",
                  "pm.test('[03.1] Username da luu vao environment', function () {",
                  "    var u = pm.environment.get('test_username');",
                  "    pm.expect(u).to.match(/^pm_\\d+$/);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"{{test_username}}\",\r\n  \"password\": \"{{test_password}}\",\r\n  \"full_name\": \"{{test_full_name}}\",\r\n  \"email\": \"{{test_username}}@gmail.com\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/register.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "register.php"
              ]
            }
          },
          "response": []
        },
        {
          "name": "03.2 - POST Dang ky trung username",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[03.2] Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[03.2] Bao loi ten dang nhap da ton tai', function () {",
                  "    pm.expect(body).to.include('T\\u00ean \\u0111\\u0103ng nh\\u1eadp \\u0111\\u00e3 t\\u1ed3n t\\u1ea1i');",
                  "});",
                  "",
                  "pm.test('[03.2] Van o trang dang ky', function () {",
                  "    pm.expect(body).to.include('\\u0110\\u0102NG K\\u00dd');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{test_username}}"
                },
                {
                  "key": "password",
                  "value": "{{test_password}}"
                },
                {
                  "key": "full_name",
                  "value": "Trung Ten"
                },
                {
                  "key": "btn_register",
                  "value": "1"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/register.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register.php"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}