        {
          "name": "01.3 - GET Login auto-fill qua URL (?u=&p=)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[01.3] Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[01.3] Username duoc dien san tu URL', function () {",
                  "    pm.expect(body).to.include('value=\"demo_user\"');",
                  "});",
                  "",
                  "pm.test('[01.3] Password duoc dien san tu URL', function () {",
                  "    pm.expect(body).to.include('value=\"demo_pass\"');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/login.php?u=demo_user&p=demo_pass",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login.php"
              ],
              "query": [
                {
                  "key": "u",
                  "value": "demo_user"
                },
                {
                  "key": "p",
                  "value": "demo_pass"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "01.4 - GET Admin dashboard (cong khai)",
          "event": [
