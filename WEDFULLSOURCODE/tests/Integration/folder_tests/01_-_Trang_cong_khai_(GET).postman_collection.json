{
  "info": {
    "name": "Royal Bid - 01 - Trang cong khai (GET)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Trang cong khai (GET)",
      "item": [
        {
          "name": "01.1 - GET Form dang nhap",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[01.1] Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[01.1] Tieu de trang dang nhap', function () {",
                  "    pm.expect(body).to.include('\\u0110\\u0102NG NH\\u1eacP');",
                  "});",
                  "",
                  "pm.test('[01.1] Co du cac field trong form', function () {",
                  "    pm.expect(body).to.include('name=\"username\"');",
                  "    pm.expect(body).to.include('name=\"password\"');",
                  "    pm.expect(body).to.include('name=\"btn_login\"');",
                  "});",
                  "",
                  "pm.test('[01.1] Co nut Truy Cap', function () {",
                  "    pm.expect(body).to.include('Truy C\\u1eadp');",
                  "});",
                  "",
                  "pm.test('[01.1] Co link den trang dang ky', function () {",
                  "    pm.expect(body).to.include('register.php');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/login.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login.php"
              ]
            }
          },
          "response": []
        },
