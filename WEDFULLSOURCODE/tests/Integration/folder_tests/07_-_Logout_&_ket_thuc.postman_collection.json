{
  "info": {
    "name": "Royal Bid - 07 - Logout & ket thuc",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "07 - Logout & ket thuc",
      "item": [
        {
          "name": "07.1 - GET Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "var code = pm.response.code;",
                  "",
                  "pm.test('[07.1] Logout thanh cong', function () {",
                  "    pm.expect(code).to.be.oneOf([200, 302]);",
                  "});",
                  "",
                  "pm.test('[07.1] Sau logout ve trang chu chua dang nhap', function () {",
                  "    pm.expect(body).to.include('\\u0110\\u0103ng nh\\u1eadp');",
                  "    pm.expect(body).to.include('\\u0110\\u0103ng k\\u00fd');",
                  "    pm.expect(body).to.not.include('Tho\\u00e1t');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/logout.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "logout.php"
              ]
            }
          },
          "response": []
        },
        {
          "name": "07.2 - GET my_bids sau logout -> phai ve login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "var code = pm.response.code;",
                  "",
                  "pm.test('[07.2] Session da huy - khong vao duoc my_bids', function () {",
                  "    var veLogin = body.includes('\\u0110\\u0102NG NH\\u1eacP') && body.includes('btn_login');",
                  "    var redirect = (code === 302);",
                  "    pm.expect(veLogin || redirect).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/my_bids.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "my_bids.php"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}