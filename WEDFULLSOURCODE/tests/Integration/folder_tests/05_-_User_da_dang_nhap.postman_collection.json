  "item": [
    {
      "name": "05 - User da dang nhap",
      "item": [
        {
          "name": "05.1 - GET my_bids (co session)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[05.1] Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[05.1] Khong co loi PHP', function () {",
                  "    pm.expect(body).to.not.match(/Fatal error|Parse error/i);",
                  "});",
                  "",
                  "pm.test('[05.1] Hien thi trang my_bids.php', function () {",
                  "    pm.expect(body).to.include('class=\"page-title\"');",
                  "    pm.expect(body).to.include('custom-table');",
                  "    pm.expect(body).to.include('glass-container');",
                  "});",
                  "",
                  "pm.test('[05.1] Co du lieu dau gia (dang dan dau / bi vuot / trong)', function () {",
                  "    var coDuLieu = body.includes('badge-lead')",
                  "                || body.includes('badge-fail')",
                  "                || body.includes('badge-won')",
                  "                || body.includes('badge-pending')",
                  "                || body.includes('badge-paid')",
                  "                || body.includes('product-thumb')",
                  "                || body.includes(\"colspan='7'\");",
                  "    pm.expect(coDuLieu).to.eql(true);",
                  "});",
                  "",
                  "pm.test('[05.1] Da dang nhap - khong thay form login', function () {",
                  "    pm.expect(body).to.not.include('name=\"btn_login\"');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/my_bids.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "my_bids.php"
              ]
            }
          },
          "response": []
        },
        {
          "name": "05.2 - GET Trang chu - lay product_id con han",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[05.2] Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Lay product_id va min_bid tu trang chu",
                  "var matchModal = body.match(/openBidModal\\('(\\d+)'\\s*,\\s*'[^']*'\\s*,\\s*(\\d+)\\)/);",
                  "if (matchModal) {",
                  "    pm.environment.set('product_id', matchModal[1]);",
                  "    var minBid = Number(matchModal[2]);",
                  "    pm.environment.set('bid_amount', String(minBid));",
                  "    pm.environment.set('bid_amount_low', '1');",
                  "    console.log('product_id:', matchModal[1], '| min bid:', minBid);",
                  "} else {",
                  "    console.log('Khong co san pham con han, dung gia tri mac dinh tu environment');",
                  "}",
                  "",
                  "pm.test('[05.2] Cap nhat product_id vao environment', function () {",
                  "    pm.expect(pm.environment.get('product_id')).to.not.be.empty;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/index.php",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "index.php"
              ]
            }
          },
          "response": []
        },
        {
          "name": "05.3 - POST Dat gia hop le",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var body = pm.response.text();",
                  "",
                  "pm.test('[05.3] Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('[05.3] Khong co loi PHP', function () {",
                  "    pm.expect(body).to.not.match(/Fatal error|Parse error/i);",
                  "});",
                  "",
                  "pm.test('[05.3] Co ket qua dat gia hop le', function () {",
                  "    var results = [",
                  "        '\\u0110\\u1ea5u gi\\u00e1 th\\u00e0nh c\\u00f4ng',",
                  "        'Phi\\u00ean \\u0111\\u1ea5u gi\\u00e1 \\u0111\\u00e3 k\\u1ebft th\\u00fac',",
                  "        'Gi\\u00e1 \\u0111\\u1ea5u ph\\u1ea3i cao h\\u01a1n'",
                  "    ];",
                  "    var matched = false;",
                  "    for (var i = 0; i < results.length; i++) {",
                  "        if (body.includes(results[i])) { matched = true; break; }",
                  "    }",
                  "    pm.environment.set('last_bid_result', matched ? 'co_ket_qua' : 'khong_ro');",
                  "    pm.expect(matched).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "product_id",
